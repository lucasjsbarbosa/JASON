# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/

# --- Tooling caches ----------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- uv / venv ---------------------------------------------------------------
.venv/
# uv.lock IS committed — reproducibility

# --- Secrets -----------------------------------------------------------------
.env
*.pat
*.token
**/credentials.json
**/yt_token.json

# --- JASON data --------------------------------------------------------------
# `data/*` (não `data/`): permite re-include via `!`. Com trailing slash
# git proíbe re-include de filhos de diretório excluído.
data/*
!data/.gitkeep
# warehouse.duckdb shippa via Git LFS (estado do projeto). Thumbnails NÃO
# (regeram via `jason ingest thumbnails`, free, vem do CDN do YouTube).
!data/warehouse.duckdb

# --- Resolved IDs (regenerable from canais.txt; may include ad-hoc additions)
canais_ids.txt

# --- Models — também shippam via Git LFS (modelo treinado é estado) ----------
!src/jason/models/artifacts/**/*.lgb
!src/jason/models/artifacts/**/*.pkl
!src/jason/models/artifacts/**/meta.json
!src/jason/models/artifacts/**/best_params.json
!src/jason/models/artifacts/bertopic_*

# --- Claude Code (session state, settings.local.json, etc.) ------------------
.claude/
.agents/
skills-lock.json

# --- IDE / OS ----------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
*:Zone.Identifier

# --- Next.js / Node.js ----
apps/web/node_modules/
apps/web/.next/
apps/web/.turbo/
apps/web/out/
apps/web/.env*.local
