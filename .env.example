# =============================================================================
# JASON — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# `.env` está no .gitignore — NUNCA commitar com chaves preenchidas.
# =============================================================================

# --- YouTube Data API v3 (chave única, 10k unidades/dia grátis) ---------------
# https://console.cloud.google.com/apis/credentials
YOUTUBE_DATA_API_KEY=

# --- YouTube Analytics OAuth (só canal próprio — métricas privadas) ----------
# https://console.cloud.google.com/apis/credentials -> OAuth client ID
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_TOKEN_PATH=~/.config/jason/yt_token.json

# --- Canal próprio (formato UC..., 24 chars) ---------------------------------
# @babygiulybaby resolve para UCjLen2Tbkj91nLnlD6nmnZQ
OWN_CHANNEL_ID=UCjLen2Tbkj91nLnlD6nmnZQ

# --- TMDb (releases de horror + subgênero — chave grátis) --------------------
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# --- Anthropic (geração de títulos via Claude) -------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Whisper local (transcrição) ---------------------------------------------
# WHISPER_MODEL: tiny, base, small, medium, large-v2, large-v3
# WHISPER_DEVICE: auto, cuda, cpu
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto

# --- Storage local -----------------------------------------------------------
DATA_DIR=./data
DUCKDB_PATH=./data/warehouse.duckdb

# --- Logging -----------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
